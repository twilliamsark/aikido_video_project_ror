<section class="space-y-6">
  <div>
    <p class="text-sm font-medium text-neutral-500">Teacher Area</p>
    <h1 class="mt-2 text-3xl font-semibold text-neutral-950">Library Management</h1>
  </div>

  <div class="grid gap-4 md:grid-cols-3">
    <div class="rounded-md border border-neutral-200 bg-white p-4 shadow-sm">
      <h2 class="font-semibold text-neutral-950">Videos</h2>
      <p class="mt-2 text-sm text-neutral-600">Create and manage dojo video entries.</p>
      <%= link_to "Manage Videos", teacher_videos_path, class: "mt-4 inline-flex rounded-md bg-neutral-900 px-3 py-2 text-sm font-medium text-white hover:bg-neutral-700" %>
    </div>

    <div class="rounded-md border border-neutral-200 bg-white p-4 shadow-sm">
      <h2 class="font-semibold text-neutral-950">Sharing</h2>
      <p class="mt-2 text-sm text-neutral-600">Create and disable public video share links.</p>
      <%= link_to "Review Videos", teacher_videos_path, class: "mt-4 inline-flex rounded-md bg-neutral-900 px-3 py-2 text-sm font-medium text-white hover:bg-neutral-700" %>
    </div>

    <div class="rounded-md border border-neutral-200 bg-white p-4 shadow-sm">
      <h2 class="font-semibold text-neutral-950">List Filters</h2>
      <p class="mt-2 text-sm text-neutral-600">Save filtered video lists and share them with students.</p>
      <%= link_to "Manage Filters", teacher_video_list_filters_path, class: "mt-4 inline-flex rounded-md bg-neutral-900 px-3 py-2 text-sm font-medium text-white hover:bg-neutral-700" %>
    </div>
  </div>
</section>
