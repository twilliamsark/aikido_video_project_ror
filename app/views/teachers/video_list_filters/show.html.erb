<section class="space-y-6">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
    <div>
      <p class="text-sm font-medium text-neutral-500">Teacher Area</p>
      <h1 class="mt-2 text-3xl font-semibold text-neutral-950"><%= @video_list_filter.name %></h1>
      <p class="mt-2 text-sm text-neutral-600"><%= @video_list_filter.query.presence || "All videos" %> · <%= Teachers::VideoListFiltersController::SORT_OPTIONS.to_h.key(@video_list_filter.sort_key) %></p>
    </div>

    <div class="flex gap-2">
      <%= link_to "Edit", edit_teacher_video_list_filter_path(@video_list_filter), class: "rounded-md border border-neutral-300 px-3.5 py-2.5 text-sm font-medium text-neutral-700 hover:bg-neutral-50" %>
      <%= link_to "All Filters", teacher_video_list_filters_path, class: "rounded-md bg-neutral-900 px-3.5 py-2.5 text-sm font-medium text-white hover:bg-neutral-700" %>
    </div>
  </div>

  <div class="grid gap-6 lg:grid-cols-[1fr_0.7fr]">
    <div class="prose max-w-none">
      <%= @video_list_filter.description %>
    </div>

    <aside class="space-y-4 rounded-md border border-neutral-200 bg-neutral-50 p-5">
      <div>
        <h2 class="text-sm font-semibold uppercase tracking-wide text-neutral-500">Search Query</h2>
        <p class="mt-1 text-sm text-neutral-800"><%= @video_list_filter.query.presence || "All videos" %></p>
      </div>

      <div>
        <h2 class="text-sm font-semibold uppercase tracking-wide text-neutral-500">Default Sort</h2>
        <p class="mt-1 text-sm text-neutral-800"><%= Teachers::VideoListFiltersController::SORT_OPTIONS.to_h.key(@video_list_filter.sort_key) %></p>
      </div>

      <div class="border-t border-neutral-200 pt-4">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-neutral-500">Share Link</h2>
        <% if @video_list_filter.active_video_list_filter_share %>
          <p class="mt-1 break-all text-sm text-neutral-800"><%= public_video_list_url(@video_list_filter.active_video_list_filter_share.token) %></p>
          <div class="mt-3 flex gap-2">
            <%= link_to "Open", public_video_list_path(@video_list_filter.active_video_list_filter_share.token), class: "rounded-md border border-neutral-300 px-3 py-1.5 text-sm font-medium text-neutral-700 hover:bg-white" %>
            <%= button_to "Unshare", teacher_video_list_filter_share_path(@video_list_filter), method: :delete, class: "rounded-md border border-neutral-300 px-3 py-1.5 text-sm font-medium text-neutral-700 hover:bg-white" %>
          </div>
        <% else %>
          <p class="mt-1 text-sm text-neutral-800">No active share link.</p>
          <%= button_to "Share", teacher_video_list_filter_share_path(@video_list_filter), method: :post, class: "mt-3 rounded-md border border-neutral-300 px-3 py-1.5 text-sm font-medium text-neutral-700 hover:bg-white" %>
        <% end %>
      </div>
    </aside>
  </div>
</section>
