<%= form_with model: [ :teacher, video_list_filter ], class: "space-y-6" do |form| %>
  <% if video_list_filter.errors.any? %>
    <div class="rounded-md border border-red-200 bg-red-50 p-4 text-sm text-red-700">
      <p class="font-semibold"><%= pluralize(video_list_filter.errors.count, "error") %> prevented this list filter from being saved.</p>
      <ul class="mt-2 list-disc space-y-1 pl-5">
        <% video_list_filter.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, class: "block text-sm font-medium text-neutral-700" %>
    <%= form.text_field :name, required: true, maxlength: 160, class: "mt-2 block w-full rounded-md border border-neutral-300 px-3 py-2 shadow-sm focus:outline-solid focus:outline-blue-600" %>
  </div>

  <div>
    <%= form.label :query, "Search query", class: "block text-sm font-medium text-neutral-700" %>
    <%= form.search_field :query, placeholder: "Title, keyword, or description", class: "mt-2 block w-full rounded-md border border-neutral-300 px-3 py-2 shadow-sm focus:outline-solid focus:outline-blue-600" %>
  </div>

  <div>
    <%= form.label :sort_key, "Default sort", class: "block text-sm font-medium text-neutral-700" %>
    <%= form.select :sort_key, options_for_select(Teachers::VideoListFiltersController::SORT_OPTIONS, video_list_filter.sort_key), {}, class: "mt-2 block w-full rounded-md border border-neutral-300 px-3 py-2 shadow-sm focus:outline-solid focus:outline-blue-600" %>
  </div>

  <div>
    <%= form.label :description, class: "block text-sm font-medium text-neutral-700" %>
    <div class="mt-2 rounded-md border border-neutral-300 bg-white shadow-sm">
      <%= form.rich_text_area :description, class: "min-h-64" %>
    </div>
  </div>

  <div class="flex items-center gap-3">
    <%= form.submit class: "cursor-pointer rounded-md bg-neutral-900 px-3.5 py-2.5 text-sm font-medium text-white hover:bg-neutral-700" %>
    <%= link_to "Cancel", teacher_video_list_filters_path, class: "text-sm font-medium text-neutral-600 hover:text-neutral-950" %>
  </div>
<% end %>
