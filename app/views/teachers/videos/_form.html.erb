<%= form_with model: [ :teacher, video ], class: "space-y-6" do |form| %>
  <% if video.errors.any? %>
    <div class="rounded-md border border-red-200 bg-red-50 p-4 text-sm text-red-700">
      <p class="font-semibold"><%= pluralize(video.errors.count, "error") %> prevented this video from being saved.</p>
      <ul class="mt-2 list-disc space-y-1 pl-5">
        <% video.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :title, class: "block text-sm font-medium text-neutral-700" %>
    <%= form.text_field :title, required: true, maxlength: 160, class: "mt-2 block w-full rounded-md border border-neutral-300 px-3 py-2 shadow-sm focus:outline-solid focus:outline-blue-600" %>
  </div>

  <div>
    <%= form.label :youtube_url, "YouTube URL", class: "block text-sm font-medium text-neutral-700" %>
    <%= form.url_field :youtube_url, required: true, class: "mt-2 block w-full rounded-md border border-neutral-300 px-3 py-2 shadow-sm focus:outline-solid focus:outline-blue-600" %>
  </div>

  <div>
    <%= form.label :keyword_names, "Keywords", class: "block text-sm font-medium text-neutral-700" %>
    <%= form.text_field :keyword_names, value: video.keyword_names, placeholder: "Ukemi, ikkyo, weapons", class: "mt-2 block w-full rounded-md border border-neutral-300 px-3 py-2 shadow-sm focus:outline-solid focus:outline-blue-600" %>
  </div>

  <div>
    <%= form.label :description, class: "block text-sm font-medium text-neutral-700" %>
    <div class="mt-2 rounded-md border border-neutral-300 bg-white shadow-sm">
      <%= form.rich_text_area :description, class: "min-h-64" %>
    </div>
  </div>

  <div class="flex items-center gap-3">
    <%= form.submit class: "cursor-pointer rounded-md bg-neutral-900 px-3.5 py-2.5 text-sm font-medium text-white hover:bg-neutral-700" %>
    <%= link_to "Cancel", teacher_videos_path, class: "text-sm font-medium text-neutral-600 hover:text-neutral-950" %>
  </div>
<% end %>
