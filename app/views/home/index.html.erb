<section class="grid gap-8 lg:grid-cols-[1.2fr_0.8fr]">
  <div class="space-y-6">
    <div>
      <p class="text-sm font-medium text-neutral-500">Single Dojo Library</p>
      <h1 class="mt-2 text-4xl font-semibold text-neutral-950">Aikido Video Library</h1>
    </div>

    <div class="grid gap-3 sm:grid-cols-2">
      <%= link_to "#", class: "rounded-md border border-neutral-200 bg-white p-4 shadow-sm transition hover:bg-neutral-50" do %>
        <span class="block text-sm font-medium text-neutral-500">Students</span>
        <span class="mt-1 block text-lg font-semibold text-neutral-950">Browse Videos</span>
      <% end %>

      <%= link_to teacher_root_path, class: "rounded-md border border-neutral-200 bg-white p-4 shadow-sm transition hover:bg-neutral-50" do %>
        <span class="block text-sm font-medium text-neutral-500">Teachers</span>
        <span class="mt-1 block text-lg font-semibold text-neutral-950">Manage Library</span>
      <% end %>
    </div>
  </div>

  <div class="rounded-md border border-neutral-200 bg-neutral-50 p-5">
    <h2 class="text-base font-semibold text-neutral-950">Milestone 1</h2>
    <ul class="mt-4 space-y-3 text-sm text-neutral-700">
      <li>Rails 8.1 application shell</li>
      <li>SQLite configuration</li>
      <li>TailwindCSS build</li>
      <li>Teacher authentication foundation</li>
      <li>Action Text foundation</li>
    </ul>
  </div>
</section>
