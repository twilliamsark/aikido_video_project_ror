<section class="space-y-6">
  <div>
    <p class="text-sm font-medium text-neutral-500">Aikido Video Library</p>
    <h1 class="mt-2 text-3xl font-semibold text-neutral-950"><%= @video.title %></h1>
  </div>

  <div class="grid gap-6 lg:grid-cols-[1fr_0.7fr]">
    <div class="space-y-4">
      <div class="aspect-video overflow-hidden rounded-md border border-neutral-200 bg-neutral-950">
        <iframe class="h-full w-full" src="https://www.youtube-nocookie.com/embed/<%= @video.youtube_video_id %>" title="<%= @video.title %> video player" allow="encrypted-media; picture-in-picture; web-share" loading="lazy" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen></iframe>
      </div>

      <div class="prose max-w-none">
        <%= @video.description %>
      </div>
    </div>

    <aside class="space-y-4 rounded-md border border-neutral-200 bg-neutral-50 p-5">
      <div>
        <h2 class="text-sm font-semibold uppercase tracking-wide text-neutral-500">Keywords</h2>
        <p class="mt-1 text-sm text-neutral-800"><%= @video.keywords.order(:name).pluck(:name).join(", ").presence || "None" %></p>
      </div>
    </aside>
  </div>
</section>
